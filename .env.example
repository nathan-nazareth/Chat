# Copy to .env.local and fill in.

# A 32+ char random string. `openssl rand -base64 32`
SESSION_PASSWORD=replace_with_a_long_random_string_at_least_32_chars_long_xxxxxxxx

# Turso (libSQL) database. Required on Vercel; optional in dev (defaults to file:.data/chat.db).
# Create one at https://turso.tech and run:
#   turso db create chat
#   turso db tokens create chat
#   turso db show chat --url
TURSO_DATABASE_URL=
TURSO_AUTH_TOKEN=

# Resend API key for sending OTP emails. If unset, OTPs are logged to the server console.
RESEND_API_KEY=
RESEND_FROM=onboarding@resend.dev
# Fallback Resend API key used when the primary key fails (quota, etc).
# Only used when RESEND_API_KEY is set and its send fails.
RESEND_FALLBACK_KEY=

# Upstash Redis (serverless Redis with HTTP API). Required in production for global
# rate limiting across serverless function instances. If unset, an in-memory (per-
# instance) limiter is used as a fallback (fine for local dev but ineffective
# across multiple Vercel functions).
# Create a free database at https://console.upstash.com → REST API
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=
