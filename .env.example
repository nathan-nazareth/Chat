# Copy to .env.local and fill in.
# A 32+ char random string. `openssl rand -base64 32`
SESSION_PASSWORD=replace_with_a_long_random_string_at_least_32_chars_long_xxxxxxxx

# Resend API key for sending OTP emails. If unset, OTPs are logged to the server console.
RESEND_API_KEY=
RESEND_FROM=onboarding@resend.dev